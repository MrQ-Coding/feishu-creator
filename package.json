{
  "name": "feishu-creator",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "A clean MCP server foundation for Feishu document automation.",
  "main": "dist/index.js",
  "bin": {
    "feishu-creator": "./dist/index.js"
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "skills:sync": "node scripts/syncSkills.mjs",
    "call:tool": "node scripts/callTool.mjs",
    "profile:bootstrap": "tsx scripts/bootstrapPlaywrightProfile.ts",
    "dev": "tsx watch src/index.ts",
    "dev:stdio": "tsx watch src/index.ts --stdio",
    "dev:http": "tsx watch src/index.ts --http",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "start:http": "node dist/index.js --http"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "zod": "^3.24.2"
  },
  "optionalDependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.0",
    "eslint": "^10.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0"
  },
  "overrides": {}
}
