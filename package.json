{
  "name": "feishu-creator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A clean MCP server foundation for Feishu document automation.",
  "main": "dist/index.js",
  "bin": {
    "feishu-creator": "./dist/index.js"
  },
  "engines": {
    "node": ">=20.17.0"
  },
  "scripts": {
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "profile:bootstrap": "tsx scripts/bootstrapPlaywrightProfile.ts",
    "dev": "tsx watch src/index.ts",
    "dev:stdio": "tsx watch src/index.ts --stdio",
    "dev:http": "tsx watch src/index.ts --http",
    "start": "node dist/index.js",
    "start:stdio": "node dist/index.js --stdio",
    "start:http": "node dist/index.js --http"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "playwright": "^1.52.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "overrides": {
    "express-rate-limit": "^8.3.0"
  }
}
