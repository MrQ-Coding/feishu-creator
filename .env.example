PORT=3333
MCP_MODE=auto
MCP_HTTP_BIND_HOST=127.0.0.1
MCP_HTTP_REQUIRE_AUTH=true
MCP_HTTP_AUTH_TOKEN=

# Feishu auth and API settings.
FEISHU_BASE_URL=https://open.feishu.cn/open-apis
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_AUTH_TYPE=tenant

# Used in user mode.
# If FEISHU_AUTH_TYPE=user and FEISHU_USER_REFRESH_TOKEN is set, startup will
# proactively refresh once when expiry metadata is missing or near expiry.
FEISHU_USER_ACCESS_TOKEN=
FEISHU_USER_REFRESH_TOKEN=
FEISHU_USER_ACCESS_TOKEN_EXPIRES_AT=
FEISHU_USER_REFRESH_TOKEN_EXPIRES_AT=

# Wiki deletion strategy (browser-based wiki deletion flow).
FEISHU_WIKI_DELETE_STRATEGY=playwright
FEISHU_UI_BASE_URL=https://my.feishu.cn
# Keep headless enabled by default. If the web session expires, the service will
# briefly open a visible browser for manual login recovery, close it, then retry
# deletion in headless mode with the same browser profile.
FEISHU_PLAYWRIGHT_HEADLESS=true
FEISHU_PLAYWRIGHT_EXECUTABLE_PATH=
# Relative paths are resolved against the MCP service project root.
FEISHU_PLAYWRIGHT_USER_DATA_DIR=.playwright/feishu-automation-profile
FEISHU_PLAYWRIGHT_ACTION_TIMEOUT_MS=45000
FEISHU_PLAYWRIGHT_LOGIN_RECOVERY_MODE=on_demand
FEISHU_PLAYWRIGHT_LOGIN_TIMEOUT_MS=180000

# Refresh threshold in seconds.
FEISHU_TOKEN_REFRESH_BEFORE_SECONDS=300
FEISHU_OAUTH_STATE_TTL_SECONDS=600

# Request performance tuning.
FEISHU_MAX_CONCURRENCY=8
FEISHU_REQUEST_MAX_RETRIES=2
FEISHU_REQUEST_BACKOFF_BASE_MS=250
FEISHU_DOC_INFO_CACHE_TTL_SECONDS=60
FEISHU_DOC_BLOCKS_CACHE_TTL_SECONDS=30
FEISHU_WIKI_SPACES_CACHE_TTL_SECONDS=120
FEISHU_WIKI_TREE_CACHE_TTL_SECONDS=120
FEISHU_WIKI_TREE_MAX_CONCURRENCY=6
FEISHU_CACHE_MAX_ENTRIES=500
FEISHU_CACHE_CLEANUP_INTERVAL_SECONDS=60
